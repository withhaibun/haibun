{
	"name": "haibun",
	"type": "module",
	"private": false,
	"workspaces": [
		"modules/*",
		"e2e-tests"
	],
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=11.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@types/node": "^25.3.0",
		"@vitest/coverage-v8": "^4.0.18",
		"concurrently": "^9.2.1",
		"dependency-cruiser": "^17.3.8",
		"playwright": "^1.58.2",
		"rollup-plugin-visualizer": "^6.0.5",
		"semantic-release": "^24.2.9",
		"typescript": "^5.9.3",
		"vite": "^6.4.1",
		"vite-plugin-singlefile": "^2.3.0",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"test": "vitest run",
		"test:integration": "npm run test:integration --workspaces --if-present",
		"start:mcp": "HAIBUN_O_MCPSTEPPER_ACCESS_TOKEN=wtw HAIBUN_O_WEBSERVERSTEPPER_PORT=8129 haibun-cli --config mcp-server/config.json mcp-server serve-mcp",
		"test-watch": "vitest --hideSkippedTests",
		"clean": "rm -rf modules/*/build modules/*/tsconfig.tsbuildinfo",
		"build-watch:tsc": "tsc -b modules/ --watch --preserveWatchOutput",
		"build:monitor-browser": "npm run build:client -w @haibun/monitor-browser",
		"build-watch:monitor-browser": "npm run dev -w @haibun/monitor-browser",
		"build": "npm run build --workspaces --if-present && npm run postbuild",
		"postbuild": "node scripts/chmod-shebangs.mjs",
		"build-watch": "concurrently \"npm:build-watch:tsc\" \"npm:build-watch:monitor-browser\"",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"depcruise": "depcruise -c .dependency-cruiser.cjs -T dot modules | dot -T svg | depcruise-wrap-stream-in-html > dependency-graph.html",
		"preversion": "npm run test",
		"version": "node scripts/sync-versions.mjs",
		"postversion": "git push --follow-tags",
		"version-alpha": "npm version prerelease --preid=alpha",
		"version-alpha:minor": "npm version preminor --preid=alpha",
		"version-alpha:major": "npm version premajor --preid=alpha",
		"version-beta": "npm version prerelease --preid=beta",
		"version-rc": "npm version prerelease --preid=rc",
		"version-graduate": "node scripts/graduate-version.mjs",
		"version-patch": "npm version patch",
		"version-minor": "npm version minor",
		"version-major": "npm version major",
		"publish-all": "node scripts/publish-all.mjs",
		"publish-all:alpha": "node scripts/publish-all.mjs alpha",
		"publish-all:beta": "node scripts/publish-all.mjs beta",
		"publish-all:rc": "node scripts/publish-all.mjs rc"
	},
	"version": "4.0.0-alpha.3",
	"overrides": {
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0"
	}
}
