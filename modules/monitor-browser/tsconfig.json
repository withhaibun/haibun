{
  "extends": "../tsconfig.settings.json",
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../domain-storage"
    },
    {
      "path": "../storage-fs"
    },
    {
      "path": "../web-playwright"
    },
    {
      "path": "../web-server-hono"
    }
  ],
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./src",
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*"
  ],
  "files": [
    "src/client/lib/timeline.ts"
  ],
  "exclude": [
