{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "node16",
		"declaration": true,
		"outDir": "build",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["node"],
		"lib": ["ES2022", "DOM"]
	},
	"include": ["src"]
}
