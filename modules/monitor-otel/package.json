{
  "name": "@haibun/monitor-otel",
  "version": "3.5.0",
  "description": "OpenTelemetry monitor for Haibun - exports traces and logs via OTLP",
  "main": "build/index.js",
  "files": [
    "build/"
  ],
  "exports": {
    ".": "./build/index.js",
    "./*": "./build/*"
  },
  "scripts": {
    "build": "tsc -b .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@haibun/core": "3.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.209.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.209.0",
    "@opentelemetry/resources": "^2.3.0",
    "@opentelemetry/sdk-logs": "^0.209.0",
    "@opentelemetry/sdk-trace-node": "^2.5.0",
    "@opentelemetry/semantic-conventions": "^1.39.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
