{
  "name": "@haibun/web-server-hono",
  "type": "module",
  "version": "4.0.0-alpha.3",
  "description": "Hono-based web server for haibun with MCP support",
  "main": "build/web-server-stepper.js",
  "files": [
    "build/**"
  ],
  "exports": {
    ".": "./build/web-server-stepper.js",
    "./*": "./build/*"
  },
  "scripts": {
    "prepublishOnly": "tsc -b .",
    "build": "tsc -b .",
    "build-watch": "tsc -b . --watch",
    "lint": "eslint -c .eslintrc.json --ext .ts,.js src",
    "preversion": "npm run lint",
    "test": "vitest run",
    "test:integration": "vitest run **/*.integration.test.ts",
    "test-watch": "vitest"
  },
  "keywords": [
    "haibun",
    "hono",
    "mcp",
    "web-server"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@haibun/core": "*",
    "@hono/mcp": "^0.2.3",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "hono": "^4.12.0",
    "zod": "4.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "eventsource": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
