{
  "name": "@haibun/web-server-hono",
  "type": "module",
  "version": "3.3.0",
  "description": "Hono-based web server for haibun with MCP support",
  "main": "build/web-server-stepper.js",
  "files": [
    "build/**"
  ],
  "exports": {
    ".": "./build/web-server-stepper.js",
    "./*": "./build/*"
  },
  "scripts": {
    "prepublishOnly": "tsc -b .",
    "build": "tsc -b .",
    "build-watch": "tsc -b . --watch",
    "lint": "eslint -c .eslintrc.json --ext .ts,.js src",
    "preversion": "npm run lint",
    "test": "vitest run",
    "test:integration": "vitest run **/*.integration.test.ts",
    "test-watch": "vitest"
  },
  "keywords": [
    "haibun",
    "hono",
    "mcp",
    "web-server"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@haibun/core": "3.3.0",
    "@hono/mcp": "^0.2.3",
    "@hono/node-server": "^1.19.7",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "hono": "^4.11.3",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@haibun/web-http": "3.3.0",
    "@types/node": "^24.10.0",
    "eventsource": "^3.0.7",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}