{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "env": {
      "type": "string",
      "enum": [
        "local",
        "dev",
        "test",
        "prod"
      ]
    },
    "dirFilters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dir": {
            "type": "string",
            "enum": [
              "smoke",
              "api"
            ]
          },
          "access": {
            "type": "string",
            "enum": [
              "r",
              "a",
              "w"
            ]
          }
        },
        "required": [
          "dir",
          "access"
        ]
      }
    }
  },
  "required": [
    "env",
    "dirFilters"
  ],
  "deny": [
    {
      "env": "prod",
      "access": "w"
    }
  ]
}